# 建置期注入（npm run build 時讀取；執行期可在擴充「設定」覆寫，見 docs/env-and-secrets-pattern.md）
# 空值時 Agent Chat URL 會退回專案內建後備網址；Firebase／OAuth Client Id 可改在設定裡填。

# staging | production — 擴充首次載入預設選哪個環境
PERSONAL_EXT_DEFAULT_ENV=staging

# Agent Chat API 完整 URL（依環境分開）
PERSONAL_EXT_AGENT_CHAT_URL_STAGING=
PERSONAL_EXT_AGENT_CHAT_URL_PRODUCTION=

# Firebase Web API Key（Identity Toolkit signInWithIdp）
PERSONAL_EXT_FIREBASE_WEB_API_KEY_STAGING=
PERSONAL_EXT_FIREBASE_WEB_API_KEY_PRODUCTION=

# Google OAuth 2.0 Client ID（Chrome extension OAuth client）
PERSONAL_EXT_GOOGLE_OAUTH_CLIENT_ID_STAGING=
PERSONAL_EXT_GOOGLE_OAUTH_CLIENT_ID_PRODUCTION=
